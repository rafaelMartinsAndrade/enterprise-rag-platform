APP_NAME=Enterprise RAG Platform
APP_ENV=local
APP_DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/enterprise_rag
API_TOKEN=change-me
DEFAULT_ORGANIZATION_SLUG=acme-erp
STORAGE_ROOT=./data/storage
LLM_PROVIDER=mock
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
CHUNK_SIZE_CHARS=900
CHUNK_OVERLAP_CHARS=180
DEFAULT_TOP_K=5
DEFAULT_SIMILARITY_THRESHOLD=0.2
RERANK_CANDIDATE_COUNT=8
PROMPT_VERSION=v1-rag-grounded
MAX_UPLOAD_SIZE_BYTES=3145728
ALLOWED_UPLOAD_TYPES=text/plain,application/pdf,text/markdown,application/json,text/csv
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
STREAMLIT_API_BASE_URL=http://localhost:8000/api/v1
